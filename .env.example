# CrisisCommand environment (see CLAUDE.md "Environment")
# Get a key at fireworks.ai -> API Keys. Without it, briefings silently fall
# back to a raw-data template (the UI says so). Verify with:
#   python scripts/check_fireworks.py --test
FIREWORKS_API_KEY=
# Model IDs churn — check_fireworks.py lists what your account can actually
# serve and warns if this one is gone. Prefer a large general instruct model:
# briefings are low-volume, quality-critical, and must emit strict JSON.
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
VLLM_ENDPOINT=http://localhost:8001/v1
# vllm on an AMD GPU (droplet or ROCm notebook) | fireworks fallback for dev
SIM_BACKEND=fireworks
# true = offline demo with curated historical events (dev + stage default)
SEED_MODE=true
